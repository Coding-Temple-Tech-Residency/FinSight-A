# App
APP_NAME=FinSight
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database
# Dev: SQLite (no Supabase needed)
# Prod: PostgreSQL from Supabase
DATABASE_URL=sqlite:///./finsight_dev.db

# JWT
JWT_SECRET_KEY=change-me-generate-with-python-secrets
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs (Sprint 2)
ALPHA_VANTAGE_API_KEY=
GROQ_API_KEY=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
